    <!-- INTERACTIVE JAVASCRIPT FOR SIMULATOR -->
    <script>
        // Store simulator items
        let currentChain = [
            { id: 'Apple', icon: '🍎', price: 5000 }
        ];
        let currentRing = 'Silver';
        const ringPrices = {
            'Silver': 10000,
            'Gold': 12000,
            'Acrylic': 8000
        };

        // Render the chain onto preview
        function renderChain() {
            const container = document.getElementById('charm-chain');
            container.innerHTML = '';

            // Render Ring Clasp
            currentChain.forEach((item, index) => {
                const charmDiv = document.createElement('div');
                charmDiv.className = "w-12 h-12 bg-white rounded-full border-pop flex items-center justify-center text-2xl transition-all duration-300 sticker-shadow hover:scale-110 cursor-pointer relative group";
                charmDiv.innerHTML = item.icon;
                
                // Remove on click
                charmDiv.onclick = () => removeCharm(index);
                
                // Tooltip
                const tooltip = document.createElement('span');
                tooltip.className = "absolute -bottom-6 bg-luvinaDark text-white text-[9px] font-bold px-1.5 py-0.5 rounded opacity-0 group-hover:opacity-100 transition duration-150 pointer-events-none z-30 whitespace-nowrap";
                tooltip.innerText = "Klik untuk hapus";
                charmDiv.appendChild(tooltip);

                container.appendChild(charmDiv);
            });

            // Update Total Price
            calculatePrice();
        }

        // Add charm
        function addCharm(name, icon, price) {
            if (currentChain.length >= 5) {
                alert("Wah, gantungan tas kamu sudah penuh! Maksimal 5 ornamen saja ya biar muat.");
                return;
            }
            currentChain.push({ id: name, icon: icon, price: price });
            renderChain();
        }

        // Add Custom letter charm
        function addLetterCharm() {
            const input = document.getElementById('initial-input');
            const letter = input.value.toUpperCase().trim();
            if (!letter) {
                alert("Ketik 1 huruf dulu ya!");
                return;
            }
            if (currentChain.length >= 5) {
                alert("Wah, gantungan tas kamu sudah penuh! Maksimal 5 ornamen saja ya.");
                return;
            }
            currentChain.push({ id: 'Letter-' + letter, icon: letter, price: 2000 });
            input.value = ''; // clear input
            renderChain();
        }

        // Remove a charm
        function removeCharm(index) {
            currentChain.splice(index, 1);
            renderChain();
        }

        // Change base ring
        function changeRing(type) {
            currentRing = type;
            
            // Toggle active buttons styling
            document.querySelectorAll('.ring-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-luvinaYellow', 'text-luvinaDark');
            });
            
            if (type === 'Silver') {
                document.getElementById('ring-silver').classList.add('active', 'bg-luvinaYellow');
            } else if (type === 'Gold') {
                document.getElementById('ring-gold').classList.add('active', 'bg-luvinaYellow');
            } else if (type === 'Acrylic') {
                document.getElementById('ring-acrylic').classList.add('active', 'bg-luvinaYellow');
            }

            calculatePrice();
        }

        // Reset all
        function resetCharm() {
            currentChain = [{ id: 'Apple', icon: '🍎', price: 5000 }];
            renderChain();
        }

        // Calculate final price
        function calculatePrice() {
            let total = ringPrices[currentRing];
            currentChain.forEach(item => {
                total += item.price;
            });

            // Format Currency
            const formatter = new Intl.NumberFormat('id-ID', {
                style: 'currency',
                currency: 'IDR',
                minimumFractionDigits: 0
            });
            document.getElementById('live-price').innerText = formatter.format(total);
        }

        // Order via WhatsApp (Generates custom link with current selection text!)
        function orderViaWhatsapp() {
            let ornamenList = currentChain.map(item => item.icon + " (" + item.id + ")").join(", ");
            if (!ornamenList) ornamenList = "Belum memilih ornamen";
            
            const message = `Halo Kak Admin Luvina! Saya mau pesan Custom Bag Charm hasil rancangan saya di Simulator Website:%0A%0A- Warna Ring: ${currentRing}%0A- Susunan Ornamen: ${ornamenList}%0A- Estimasi Harga: ${document.getElementById('live-price').innerText}%0A%0AApakah bisa langsung diproses Kak? ✨`;
            
            window.open(`https://wa.me/628123456789?text=${message}`, '_blank');
        }

        // Initialize
        renderChain();
    </script>
